PORT=3000
DATABASE_URL=postgres://spotify_backup:spotify_backup@127.0.0.1:5432/spotify_backup

# Create an app at https://developer.spotify.com/dashboard
# Add this exact redirect URI to the Spotify app:
# http://127.0.0.1:3000/auth/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# Use a long random value for anything beyond local development.
SESSION_SECRET=replace-with-a-long-random-local-secret
